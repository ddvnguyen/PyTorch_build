{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/server",
    "rootDir": "app/server",
    "types": ["node"]
  },
  "include": ["app/server/**/*.ts"],
  "exclude": ["app/server/**/*.test.ts"]
}
